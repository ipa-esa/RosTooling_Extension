aruco_ros:
    artifacts:
        marker_publisher:
            node: marker_publisher
            subscribers:
                image_raw:
                    type: "sensor_msgs/msg/Image"
            publishers:
                debug:
                    type: "sensor_msgs/msg/Image"
                markers:
                    type: "aruco_msgs/msg/MarkerArray"
                markers_list:
                    type: "std_msgs/msg/UInt32MultiArray"
                res:
                    type: 'sensor_msgs/msg/Image'
            parameters:
                camera_frame:
                    type: String
                image_is_rectified:
                    type: Boolean
                marker_size:
                    type: Double
rossdl_simple_test:
  nodes:
    node1:
      from: "rossdl_simple_test.image_filter"
      interfaces:
        - image_pub: pub-> "image_filter::image_out"
        - description_pub: pub-> "image_filter::description_out"
        - image_sub: sub-> "image_filter::image_in"
        - laser_sub: sub-> "image_filter::laser_in"
      parameters:
        - DescriptionLabel: "image_filter::description_label"
          value: "image_raw"
    node2:
      from: "rossdl_simple_test.consumer"
      interfaces:
        - image_sub: sub-> "consumer::image_in"
        - description_sub: sub-> "consumer::description_in"
        - image_pub: pub-> "consumer::image_out"
  processes:
    process1:
      nodes: [node1, node2]
      threads: 2
{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ros",
  "scopeName": "source.ros",
  "patterns": [
    { "include": "#keywords" },
    { "include": "#package" },
    { "include": "#interface" },
    { "include": "#primitives" }
  ],
  "repository": {
    "keywords": {
      "patterns": [{
        "name": "keyword.control.ros",
        "match": "^\\s*(msgs|srvs|actions|message|request|response|goal|result|feedback):?"
      }]
    },
    "primitives": {
      "patterns": [{
        "name": "storage.type.primitive.ros",
        "match": "^\\s*(bool|string|time|Header|(u?int|float)(8|16|32|64))(\\[\\])?(?=\\s|$|[\\s,])"
      }]
    },
    "package": {
      "patterns": [{
        "comment": "Package: Indentation level 0, before keywords",
        "match": "^([a-zA-Z_][a-zA-Z0-9_]*)(?=:|\\s*$):",
        "name": "entity.name.class.ros"
      }]
    },
    "interface": {
      "patterns": [{
        "comment": "Interface: Indentation level 2 (4 or 8 spaces)",
        "match": "^( {4}| {8}|\\t{2})([A-Z][a-zA-Z0-9_]*)",
        "captures": {
          "2": { "name": "markup.raw.ros" }
        }
      }]
    }
  }
}
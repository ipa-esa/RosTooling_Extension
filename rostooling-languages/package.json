{
  "name": "rostooling-languages",
  "displayName": "Rostooling Languages",
  "description": "Plugin to support Rostooling languages",
  "version": "1.0.1",
  "publisher": "FraunhoferIPA",
  "icon": "images/Fraunhofer-logo.svg.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ipa-esa/RosTooling_Extension.git"
  },
  "bugs": {
    "url": "https://github.com/ipa-esa/RosTooling_Extension/issues"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ros",
        "aliases": [
          "ROS",
          "ros"
        ],
        "extensions": [
          ".ros"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "ros1",
        "aliases": [
          "ROS1",
          "ros1"
        ],
        "extensions": [
          ".ros1"
        ]
      },
      {
        "id": "ros2",
        "aliases": [
          "ROS2",
          "ros2"
        ],
        "extensions": [
          ".ros2"
        ]
      },
      {
        "id": "rossystem",
        "aliases": [
          "ROS System",
          "rossystem"
        ],
        "extensions": [
          ".rossystem"
        ]
      }
    ],
    "grammars": [
      {
        "language": "ros",
        "scopeName": "source.ros",
        "path": "./syntaxes/ros.tmLanguage.json"
      },
      {
        "language": "ros1",
        "scopeName": "source.ros1",
        "path": "./syntaxes/ros1.tmLanguage.json"
      },
      {
        "language": "ros2",
        "scopeName": "source.ros2",
        "path": "./syntaxes/ros2.tmLanguage.json"
      },
      {
        "language": "rossystem",
        "scopeName": "source.rossystem",
        "path": "./syntaxes/rossystem.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[rossystem]": {
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "punctuation.bracket.yellow.ros",
              "settings": {
                "foreground": "#FFD700",
                "fontStyle": "bold"
              }
            }
          ]
        }
      }
    },
    "assetResources": [
      "server/**/*"
    ],
    "configuration": {
      "title": "ROS Tooling LSP",
      "properties": {
        "rostooling-languages.server.trace": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "scope": "window"
        }
      }
    },
    "commands": [
      {
        "command": "rossystem.triggerCodeGeneration",
        "title": "ROSSYSTEM: Generate Code",
        "category": "rossystem"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "rossystem.triggerCodeGeneration",
          "group": "ROSSYSTEM@100",
          "when": "resourceLangId == rossystem"
        }
      ]
    }
  },
  "activationEvents": [
    "onLanguage:ros",
    "onLanguage:ros1",
    "onLanguage:ros2",
    "onLanguage:rossystem"
  ],
  "main": "./out/extension.js",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint \"src/**/*.{*-ts,tsx,js,jsx}\"",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.25.1",
    "eslint": "^9.39.3",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
